# Database Configuration
DB_CONTAINER=your-container-name
DB_PORT=3308
MYSQL_HOST=localhost
MYSQL_DATABASE=salonease_db

# Database Users (REQUIRED - no defaults)
MYSQL_ROOT_USER=root
MYSQL_ROOT_PASSWORD=your-secure-password
MYSQL_USER=salonease_user
MYSQL_PASS=your-user-password

# phpMyAdmin Configuration
PMA_HOST=your-container-name
PMA_USER=root
PMA_PASSWORD=your-secure-password

# Session Configuration
SESSION_SECRET=your-unique-session-secret-key

# IMPORTANT:
# 1. Copy this file to .env
# 2. Replace all placeholder values with actual secure values
# 3. Never commit .env to version control
# 4. Use strong, unique passwords
