# Database Configuration
DB_CONTAINER=salonease-db
DB_PORT=3306
MYSQL_HOST=salonease-db
MYSQL_DATABASE=salonease_db

# MySQL Users Configuration
# IMPORTANT: MySQL Docker image always creates 'root' user
# MYSQL_ROOT_USER is only used by application code, not by MySQL container
MYSQL_ROOT_USER=dbroot          # Used by application (not MySQL)
MYSQL_ROOT_PASSWORD=your-secure-password  # Password for MySQL 'root' user
MYSQL_USER=dbuser              # Additional MySQL user
MYSQL_PASS=your-user-password  # Password for dbuser

# phpMyAdmin Configuration
# Note: Use 'root' as PMA_USER because MySQL container creates 'root' user
PMA_HOST=salonease-db          # MySQL container name
PMA_USER=root                  # MySQL actual root user
PMA_PASSWORD=your-secure-password  # MySQL root password

# JWT Configuration
JWT_SECRET=your-jwt-secret-key

# Application Configuration
PORT=3000
HOST=0.0.0.0

# SETUP INSTRUCTIONS:
# 1. Copy this file to .env: cp .env.example .env
# 2. Replace all placeholder values with actual secure values
# 3. Never commit .env to version control (add to .gitignore)
# 4. Use strong, unique passwords for production
# 5. MYSQL_ROOT_USER is for app code only - MySQL always uses 'root' user
