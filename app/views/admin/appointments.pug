extends ../layout
include ../partials/_adminSidebar
include ../partials/_appointmentCard
include ../partials/_modals

block content
  .app-layout
    +adminSidebar('appointments')

    .main-content
      .page-header
        span.breadcrumb Appointments

      .page-body
        h1.page-title Appointments Management
        p.page-subtitle View and manage all appointments

        #status-filters.filter-bar
          button.filter-btn.active(data-status="all") All
          button.filter-btn(data-status="in_review") In Review
          button.filter-btn(data-status="confirmed") Confirmed
          button.filter-btn(data-status="completed") Completed
          button.filter-btn(data-status="cancelled") Cancelled

        #appointments-container
          .loading-spinner-wrap
            .spinner
            p Loading appointments...

    +appointmentCardTemplate()

  //- Appointment Detail Modal
  .modal-overlay#detail-modal
    .modal
      .modal-header
        h3#detail-modal-title Appointment Details
        button.modal-close(onclick="closeModal('detail-modal')") &times;
      .modal-body
        #detail-appt-info
        #detail-appt-actions.modal-actions

  +confirmModal()
  +cancelModal()
  +completeModal()

block scripts
  script(src="/js/admin/appointments.js")
