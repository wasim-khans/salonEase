extends ../layout
include ../partials/_adminSidebar

block content
  .app-layout
    +adminSidebar('services')

    .main-content
      .page-header
        span.breadcrumb Services Management
        button.btn.btn-primary Add Service

      .page-body
        h1.page-title Admin Services
        p.page-subtitle Manage all salon services

        table.services-table
          thead
            tr
              th Name
              th Category
              th Price
              th Duration
              th Actions
          tbody#servicesTable

      // Create Service Modal
      .modal.fade#createServiceModal(tabindex="-1" role="dialog")
        .modal-dialog(role="document")
          .modal-content
            .modal-header
              h5.modal-title Create New Service
              button.close(type="button" data-dismiss="modal" aria-label="Close")
                span(aria-hidden="true") ×
            .modal-body
              form
                .form-group
                  label(for="serviceName") Service Name
                  input.form-control#serviceName(type="text" name="name" required)
                
                .form-group
                  label(for="serviceCategory") Category
                  select.form-control#serviceCategory(name="category" required)
                    option(value="male") Male
                    option(value="female") Female
                    option(value="both") Both
                
                .form-group
                  label(for="servicePrice") Base Price (£)
                  input.form-control#servicePrice(type="number" step="0.01" min="0" name="base_price" required)
                
                .form-group
                  label(for="serviceDuration") Duration (minutes)
                  input.form-control#serviceDuration(type="number" min="15" step="5" name="duration" required)
            
            .modal-footer
              button.btn.btn-secondary(type="button" data-dismiss="modal") Cancel
              button.btn.btn-primary(type="submit") Save Service

        p.section-label ALL SERVICES

        .services-grid
          .service-card
            h3.service-name Haircut
            p.service-desc Quick trim to full restyle
            p.service-price from £15.00
            a.btn-book(href="/customer/book") Book →

          .service-card
            h3.service-name Hair colouring
            p.service-desc Tints, highlights, balayage
            p.service-price from £45.00
            a.btn-book(href="/customer/book") Book →

          .service-card
            h3.service-name Hair treatment
            p.service-desc Deep conditioning & repair
            p.service-price from £30.00
            a.btn-book(href="/customer/book") Book →

          .service-card
            h3.service-name Manicure
            p.service-desc Classic & gel options
            p.service-price from £20.00
            a.btn-book(href="/customer/book") Book →

          .service-card
            h3.service-name Pedicure
            p.service-desc Relaxing foot treatment
            p.service-price from £25.00
            a.btn-book(href="/customer/book") Book →

          .service-card
            h3.service-name Waxing
            p.service-desc Full body waxing available
            p.service-price from £18.00
            a.btn-book(href="/customer/book") Book →

block scripts