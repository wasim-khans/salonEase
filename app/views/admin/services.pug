extends ../layout
include ../partials/_adminSidebar

block content
  .app-layout
    +adminSidebar('services')

    .main-content
      .page-header
        span.breadcrumb Service Management

      .page-body
        h1.page-title Services
        p.page-subtitle Manage your salon services

        button.btn-primary(onclick="openAddServiceModal()") + Add Service

        table.appointments-table
          thead
            tr
              th Name
              th Category
              th Price
              th Duration
              th Actions
          tbody#services-table-body
            tr
              td(colspan="5")
                .loading-spinner-wrap
                  .spinner
                  p Loading services...

  //- Add / Edit Service Modal
  .modal-overlay#service-modal
    .modal
      .modal-header
        h3#service-modal-title Add Service
        button.modal-close(onclick="closeModal('service-modal')") &times;
      .modal-body
        form#service-form
          .form-group
            label(for="service-name") Name
            input#service-name(type="text" required)
          .form-group
            label(for="service-category") Category
            select#service-category
              option(value="both") Both
              option(value="male") Male
              option(value="female") Female
          .form-group
            label(for="service-price") Base Price (£)
            input#service-price(type="number" step="0.01" min="0" required)
          .form-group
            label(for="service-duration") Duration (minutes)
            input#service-duration(type="number" min="1" required)
          .modal-actions
            button.btn-outline(type="button" onclick="closeModal('service-modal')") Cancel
            button.btn-primary(type="submit") Save

  //- Delete Confirmation Modal
  .modal-overlay#delete-service-modal
    .modal
      .modal-header
        h3 Delete Service
        button.modal-close(onclick="closeModal('delete-service-modal')") &times;
      .modal-body
        p Are you sure you want to delete this service? This action cannot be undone.
        .modal-actions
          button.btn-outline(type="button" onclick="closeModal('delete-service-modal')") Cancel
          button.btn-action-danger(type="button" onclick="confirmDeleteService()" style="background:#fff5f5; border:1px solid #e74c3c; color:#e74c3c; padding:0.75rem; border-radius:6px; cursor:pointer; flex:1;") Delete

block scripts
  script(src="/js/admin/services.js")