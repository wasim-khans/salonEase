extends ../layout

block content
  .auth-split
    .auth-split-image(style="background-image: linear-gradient(rgba(0,0,0,0.4), rgba(0,0,0,0.4)), url('/images/auth/login.jpg')")
      .auth-split-image-text
        h2 SalonEase
        p Your perfect salon experience, just a tap away

    .auth-split-form
      .auth-split-form-inner
        h1.auth-title Sign in
        p.auth-subtitle Welcome back

        form#loginForm
          .field
            label(for="email") Email address
            input#email(type="email" name="email" placeholder="email@example.com" required)

          .field
            label(for="password") Password
            input#password(type="password" name="password" placeholder="••••••••" required)

          button.btn-full-width.btn-primary(type="submit") Sign in

        p.auth-footer Don't have an account?&nbsp;
          a(href="/auth/register") Register

block scripts
  script(src="/js/auth/login.js")
