extends ../layout

block content
  .auth-wrapper
    .auth-card
      h1.auth-title Create account
      p.auth-subtitle Sign up to start booking appointments

      form(action="/api/auth/register" method="POST")
        .field
          label(for="name") Full name
          input#name(type="text" name="name" placeholder="Your name")

        .field
          label(for="email") Email address
          input#email(type="email" name="email" placeholder="email@example.com")

        .field
          label(for="phone") Phone number
          input#phone(type="tel" name="phone" placeholder="+44 7700 000000")

        .field
          label(for="password") Password
          input#password(type="password" name="password" placeholder="••••••••")

        button.btn-primary(type="submit") Create account

      p.auth-footer Already have an account?&nbsp;
        a(href="/auth/login") Sign in