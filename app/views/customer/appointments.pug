extends ../layout
include ../partials/_customerSidebar
include ../partials/_modals

block content
  .app-layout
    +customerSidebar('appointments')

    .main-content
      .page-header
        span My Appointments

      .page-body
        #appointments-view
          h1.page-title My Appointments

          p.section-label Upcoming
          #upcoming-container
            .loading-spinner-wrap
              .spinner
              p Loading appointments...

          p.section-label Past
          #past-container

        #cancelled-view(style="display:none")
          .cancelled-state
            .cancelled-icon ✕
            h2.cancelled-title Booking Cancelled
            p.cancelled-subtitle Your appointment has been cancelled
            .modal-appt-info
              strong#cancelled-appt-name
              span#cancelled-appt-datetime
            .cancelled-actions
              a.btn-cancelled-secondary(href="/customer/appointments") View Bookings
              a.btn-cancelled-primary(href="/customer/services") Book a Service

  +editModal()
  +cancelModal()

block scripts
  script(src="/js/customer/appointments.js")
