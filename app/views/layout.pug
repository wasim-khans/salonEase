doctype html
html
  head
    meta(charset="UTF-8")
    meta(name="viewport" content="width=device-width, initial-scale=1.0")
    title SalonEase
    link(rel="stylesheet" href="/css/style.css")
    script(src="/js/utilities/notifications.js")
    script(src="/js/utilities/apiRequests.js")
    script(src="/js/logout.js")
  body
    header.topbar
      .topbar-inner
        a.brand#brand-link(href="/") SalonEase
    block content
    block scripts
    script.
      (function() {
        var user = localStorage.getItem('user');
        if (user) {
          try {
            var parsed = JSON.parse(user);
            var link = document.getElementById('brand-link');
            if (link && parsed.type === 'admin') link.href = '/admin/appointments';
            else if (link && parsed.type === 'customer') link.href = '/customer/appointments';
            var label = document.getElementById('sidebar-user-name');
            if (label && parsed.name) label.textContent = parsed.name;
          } catch(e) {}
        }
      })();