mixin adminSidebar(active)
  nav.sidebar
    span.sidebar-label Admin
    a.sidebar-item(href="/admin/appointments" class=(active === 'appointments' ? 'active' : '')) Appointments
    a.sidebar-item(href="/admin/services" class=(active === 'services' ? 'active' : '')) Services
    a.sidebar-item(href="/admin/staff" class=(active === 'staff' ? 'active' : '')) Staff
    a.sidebar-item.logout(href="#" onclick="logout(); return false;") Logout
