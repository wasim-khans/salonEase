mixin adminSidebar(activeItem)
  .sidebar
    .sidebar-header
      .logo
        img(src="/images/salon-logo.png", alt="SalonEase")
      h2 SalonEase
    .sidebar-menu
      ul
        li(class=activeItem === 'dashboard' ? 'active' : '')
          a(href="/admin/dashboard")
            i.fas.fa-tachometer-alt
            | Dashboard
        li(class=activeItem === 'appointments' ? 'active' : '')
          a(href="/admin/appointments")
            i.fas.fa-calendar-alt
            | Appointments
        li(class=activeItem === 'services' ? 'active' : '')
          a(href="/admin/services")
            i.fas.fa-cut
            | Services
        li(class=activeItem === 'staff' ? 'active' : '')
          a(href="/admin/staff")
            i.fas.fa-users
            | Staff
        li.divider
        li.logout
          a(href="#logout", onclick="logout(); return false;")
            i.fas.fa-sign-out-alt
            | Logout
