mixin customerSidebar(active)
  nav.sidebar
    a.sidebar-item(href="/customer/services" class=(active === 'services' ? 'active' : '')) Services
    a.sidebar-item(href="/customer/appointments" class=(active === 'appointments' ? 'active' : '')) My Appointments
    a.sidebar-item(href="/customer/book" class=(active === 'book' ? 'active' : '')) Book
    a.sidebar-item.logout(href="/") Log out
